# .env.example — GUARD pipeline configuration
# Copy to .env and fill in values

# Server
PORT=8001
HOST=0.0.0.0

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Reference data
BOWTIE2_INDEX_PATH=data/references/H37Rv
H37RV_FASTA_PATH=data/references/H37Rv.fasta

# Scoring models
CNN_WEIGHTS_PATH=guard/weights/seq_cnn_best.pt
CALIBRATION_PATH=guard/weights/calibration.json

# Optional: Deployment
# RAILWAY_URL=https://guard-api.up.railway.app
# VERCEL_URL=https://guard.vercel.app
