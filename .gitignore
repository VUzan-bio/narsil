# ═══════════════════════════════════════════════════════════════
# GUARD — .gitignore
# ═══════════════════════════════════════════════════════════════

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
*.whl
dist/
build/
.venv/
venv/
env/
.python-version

# Environment variables (NEVER commit secrets)
.env
.env.*
!.env.example

# Claude Code session data
.claude/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Node — root level (shouldn't exist here, safety catch)
/node_modules/
/package-lock.json

# Frontend
guard-ui/node_modules/
guard-ui/dist/
guard-ui/.env
guard-ui/.env.*

# Pipeline outputs (regenerated every run)
results/
results/**
*.json.bak

# Bowtie2 index files (built from H37Rv.fasta via bowtie2-build)
data/references/*.bt2
data/references/*.bt2l

# Training data (large, downloaded separately — see README)
data/kim2018/raw/
data/huang2024/
guard/data/kim2018/raw/
guard/data/kim2018/r_package/
guard/data/huang2024/

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Logs
*.log
logs/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
